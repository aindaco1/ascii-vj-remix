# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Video files (too large for GitHub, user provides their own)
*.mp4
*.avi
*.mov
*.mkv
*.webm

# Environment & IDE
.env
.DS_Store
dist/
node_modules/
.venv/
.venv-linux/
.venv-*/
venv/
.vscode/
.idea/

# Tauri / Rust build output
src-tauri/target/
src-tauri/gen/
src-tauri/*.key
src-tauri/*.key.pub
src-tauri/*private*
src-tauri/resources/ffmpeg/*/bin/
src-tauri/resources/ffmpeg/*/manifest.json
src-tauri/resources/ffmpeg/*/NOTICE.md

# Experiment artifacts (scripts are tracked; generated outputs are not)
experiments/vectors/
experiments/*.png

# Personal notes
mynotes.txt

# Old versions
*-previous-ver-*

# Autobahn conformance reports (regenerated by the test run)
experiments/autobahn/reports/

# stray temp dirs
tmp*/
